# Application
NODE_ENV=development
PORT=5050

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/event_mgmt

# JWT
JWT_SECRET=replace_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Frontend
CLIENT_URL=http://localhost:5173

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Campus Events <no-reply@campus.local>"
