# Environment
NODE_ENV=development

# Server
PORT=5050

# Database
MONGO_URI=mongodb://127.0.0.1:27017/event_mgmt

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL
CLIENT_URL=http://localhost:5173

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender Email
EMAIL_FROM="Campus Events <no-reply@campus.local>"
